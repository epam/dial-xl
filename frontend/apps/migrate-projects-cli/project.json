{
  "name": "migrate-projects-cli",
  "root": "apps/migrate-projects-cli",
  "projectType": "application",
  "tags": ["type:cli"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/migrate-projects-cli",
        "command": "vitest run"
      },
      "cache": true,
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{projectRoot}/test-output"]
    }
  }
}
